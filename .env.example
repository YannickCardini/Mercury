# ── Mercury backend — variables d'environnement ──────────────────────────────
# Copier ce fichier vers .env (jamais commité) et remplir les valeurs.

# Audiences OAuth Google (client IDs web et Android)
GOOGLE_AUDIENCE_WEB=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_AUDIENCE_ANDROID=xxxxxxxxxxxx.apps.googleusercontent.com

# Azure Cosmos DB — chaîne de connexion complète (prod) et émulateur local
COSMOS_CONNECTION_STRING=AccountEndpoint=https://...;AccountKey=...;
COSMOS_CONNECTION_STRING_LOCAL=AccountEndpoint=https://localhost:8081/;AccountKey=...;

# Secret partagé avec le service d'agents IA (POST /api/auth/bot + dispatch).
BOT_SECRET=change-me-before-prod

# Endpoint du service d'agents IA (matchmaking). Vide = dispatch désactivé.
AGENT_URL=https://agent-service.example.com

# Compte staff (revue Google Play) — utilisateur 1337
WORKER_USERNAME=
WORKER_PASSWORD=
WORKER_SESSION_TOKEN=

# Secret HS256 des session tokens (≥ 32 caractères aléatoires recommandés)
SESSION_JWT_SECRET=

# Origines navigateur autorisées (CORS + WebSocket), séparées par des virgules.
# Sans cette variable, seuls localhost (dev) et Capacitor sont autorisés —
# À CONFIGURER EN PROD avec l'URL du frontend déployé.
ALLOWED_ORIGINS=https://votre-frontend.example.com,https://localhost,capacitor://localhost

# true = mode debug : autorise les messages start/createRoom/joinRoom (parties
# de test single-device) et le joinMatchmaking debug vs 3 bots locaux.
DEBUG=false

# true = self-play (entraînement) : pas de dispatch d'agents externes.
TRAIN_MODE=false
