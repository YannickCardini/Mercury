{
  "name": "keezen",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=packages/shared",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run start --workspace=apps/frontend",
    "build:all": "npm run build:shared && npm run build --workspace=apps/backend"
  }
}
